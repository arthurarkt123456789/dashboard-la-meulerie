# ─────────────────────────────────────────────────────────────────────
# APITIC integration
# Set APITIC_ENABLED=true to switch off the mock data generator.
# ─────────────────────────────────────────────────────────────────────
APITIC_ENABLED=false

# Production: https://bi-data-api.web-caisse.com/api/v1
# Staging:    https://preprod-bi-data-api.web-caisse.com/api/v1
APITIC_BASE_URL=https://preprod-bi-data-api.web-caisse.com/api/v1

# Credentials used to POST /token
APITIC_EMAIL=
APITIC_PASSWORD=

# Store mapping: maps our internal store ids to APITIC account ids.
# Run `GET /api/admin/discover` once logged in to see your accounts and
# fill in these values.
APITIC_ACCOUNT_DAVSO=
APITIC_ACCOUNT_ENDOUME=
APITIC_ACCOUNT_MALMOUSQUE=
APITIC_ACCOUNT_REPUBLIQUE=

# Category → segment mapping. Comma-separated category IDs.
# Anything not listed defaults to APITIC_DEFAULT_SEGMENT (default: Snacking).
# Fill these in after running /api/admin/discover.
APITIC_CATEGORIES_FROMAGERIE=
APITIC_CATEGORIES_SNACKING=
APITIC_DEFAULT_SEGMENT=Snacking

# If true (default), fall back to mock when APITIC is unreachable or in a
# blackout window. If false, the UI surfaces an error banner.
APITIC_FALLBACK_TO_MOCK=true

# Override the demo "today" anchor used by the mock generator. Ignored when
# APITIC is enabled.
MOCK_TODAY=2026-05-19

# ─────────────────────────────────────────────────────────────────────
# Dashboard password gate (single shared password).
# When set, every page redirects to /login until the visitor enters the
# password. Leave empty to disable the gate entirely (e.g. local dev).
# ─────────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# Admin routes (/api/admin/*) shared-secret protection. Separate from
# the dashboard password — these are server-to-server diagnostic routes.
# ─────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Cache storage (persistent volume on Railway, etc.)
# ─────────────────────────────────────────────────────────────────────
# APITIC_CACHE_DIR=/data/apitic

# Number of days of history to keep cached per store. 540 gives full N-1
# coverage on the 90d view; 365 covers all other periods; 90 is the bare
# minimum for "no N-1, only P-1".
APITIC_HISTORY_DAYS=540
